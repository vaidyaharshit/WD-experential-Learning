<script>
function calculatePrice() {
  const checkin  = new Date(document.getElementById("checkin").value);
  const checkout = new Date(document.getElementById("checkout").value);
  const price    = parseInt(document.getElementById("room").value);
  const days     = (checkout - checkin) / (1000 * 60 * 60 * 24);
  if (days > 0) {
    const total = days * price;
    document.getElementById("total").innerText = "₹" + total.toLocaleString('en-IN');
    document.getElementById("payAmount").innerText = "Amount: ₹" + total.toLocaleString('en-IN');
    const upiLink = "upi://pay?pa=grandplaza@upi&pn=GrandPlazaHotel&am=" + total + "&cu=INR";
    const qrURL = "https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=" + encodeURIComponent(upiLink);
    document.getElementById("qrImage").src = qrURL;
    document.getElementById("payment").scrollIntoView({ behavior: "smooth" });
  } else {
    alert("Please select valid check-in and check-out dates.");
    return false;
  }
  return false;
}
function paymentSuccess() {
  alert("✅ Payment Successful!\nYour booking is confirmed.\nThank you for choosing Grand Plaza Hotel.");
}

function recommendRoom(event) {
  event.preventDefault();
  const guests = parseInt(document.getElementById("recoGuests").value, 10);
  const budget = parseInt(document.getElementById("recoBudget").value, 10);
  const purpose = document.getElementById("recoPurpose").value;
  const feature = document.getElementById("recoFeature").value;

  let roomName = "Deluxe Room";
  let reason = "Balanced comfort and value, perfect for most stays.";

  if (budget <= 700 || feature === "value") {
    roomName = "Dormitory";
    reason = "Best budget option with essential comfort for short stays.";
  } else if (guests >= 3 || feature === "space" || purpose === "family") {
    roomName = "Executive Suite";
    reason = "Spacious layout and premium amenities for families or groups.";
  } else if (budget <= 2800 || feature === "view" || purpose === "couple") {
    roomName = "Superior Room";
    reason = "Great city view and elevated experience for relaxed stays.";
  } else if (purpose === "work" || feature === "wifi") {
    roomName = "Deluxe Room";
    reason = "Strong WiFi, calm interior, and practical setup for work trips.";
  }

  const result = document.getElementById("recoResult");
  result.innerHTML = "<h4>Recommended Room: " + roomName + "</h4><p style='color:var(--text)'>" + reason + "</p>";
  return false;
}

let generatedOtp = "";

function switchAuthTab(tab, btn) {
  document.querySelectorAll(".auth-tab").forEach(el => el.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("mobilePane").classList.toggle("active", tab === "mobile");
  document.getElementById("gmailPane").classList.toggle("active", tab === "gmail");
}

function sendOtp() {
  const mobile = document.getElementById("mobileNumber").value.trim();
  if (!/^[6-9]\d{9}$/.test(mobile)) {
    alert("Please enter a valid 10-digit Indian mobile number.");
    return;
  }
  generatedOtp = String(Math.floor(100000 + Math.random() * 900000));
  alert("Demo OTP for " + mobile + ": " + generatedOtp);
}

function verifyOtp(event) {
  event.preventDefault();
  const otp = document.getElementById("otpInput").value.trim();
  if (!generatedOtp) {
    alert("Please click Send OTP first.");
    return false;
  }
  if (otp === generatedOtp) {
    alert("✅ Mobile login successful. Welcome to Grand Plaza!");
    return false;
  }
  alert("Invalid OTP. Please try again.");
  return false;
}

function loginWithGmail(event) {
  event.preventDefault();
  const email = document.getElementById("gmailAddress").value.trim();
  if (!/@gmail\.com$/i.test(email)) {
    alert("Please use a valid Gmail address.");
    return false;
  }
  alert("✅ Gmail login successful. Welcome to Grand Plaza!");
  return false;
}

function continueWithGoogle() {
  alert("Google Sign-In button clicked.\nConnect this with Firebase Auth or Google OAuth in production.");
}

function selectTourRoom(button, src) {
  const frame = document.querySelector("#tour360 .tour-frame");
  if (frame) frame.src = src;
  document.querySelectorAll("#tour360 .tour-room-btn").forEach(btn => btn.classList.remove("active"));
  button.classList.add("active");
}

let gatewayOtp = "";

document.body.classList.add("auth-locked");

function gatewaySwitchTab(tab, btn) {
  const gateway = document.getElementById("authGateway");
  gateway.querySelectorAll(".auth-tab").forEach(el => el.classList.remove("active"));
  btn.classList.add("active");
  document.getElementById("gatewayMobilePane").classList.toggle("active", tab === "mobile");
  document.getElementById("gatewayGmailPane").classList.toggle("active", tab === "gmail");
}

function gatewaySendOtp() {
  const mobile = document.getElementById("gatewayMobileNumber").value.trim();
  if (!/^[6-9]\d{9}$/.test(mobile)) {
    alert("Please enter a valid 10-digit Indian mobile number.");
    return;
  }
  gatewayOtp = String(Math.floor(100000 + Math.random() * 900000));
  alert("Demo OTP for " + mobile + ": " + gatewayOtp);
}

function unlockWebsite() {
  document.body.classList.remove("auth-locked");
  const gate = document.getElementById("authGateway");
  if (gate) gate.style.display = "none";
  window.scrollTo({ top: 0, behavior: "smooth" });
}

function gatewayVerifyOtp(event) {
  event.preventDefault();
  const otp = document.getElementById("gatewayOtpInput").value.trim();
  if (!gatewayOtp) {
    alert("Please click Send OTP first.");
    return false;
  }
  if (otp !== gatewayOtp) {
    alert("Invalid OTP. Please try again.");
    return false;
  }
  alert("✅ Login successful. Welcome to Grand Plaza!");
  unlockWebsite();
  return false;
}

function gatewayLoginWithGmail(event) {
  event.preventDefault();
  const email = document.getElementById("gatewayGmailAddress").value.trim();
  if (!/@gmail\.com$/i.test(email)) {
    alert("Please use a valid Gmail address.");
    return false;
  }
  alert("✅ Gmail login successful. Welcome to Grand Plaza!");
  unlockWebsite();
  return false;
}

function gatewayContinueWithGoogle() {
  alert("Google Sign-In simulated.\nConnect this with Firebase Auth for production.");
  unlockWebsite();
}

// Scroll reveal
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) { setTimeout(() => e.target.classList.add('visible'), i * 80); observer.unobserve(e.target); }
  });
}, { threshold: 0.12 });
reveals.forEach(el => observer.observe(el));

// Parallax on video
window.addEventListener('scroll', () => {
  const y = window.scrollY;
  const video = document.querySelector('.hero-video');
  if (video) video.style.transform = 'translateY(' + (y * 0.3) + 'px)';
});
</script>
