<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grand Plaza Hotel & Resort</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@200;300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --gold: #C9A84C;
    --gold-light: #F5E6C0;
    --dark: #0D0B08;
    --dark2: #1A1410;
    --cream: #FAF6EE;
    --text: #3A2E22;
    --muted: #7A6E60;
    --border: #E0D5C0;
    --white: #FFFFFF;
    --shadow: 0 4px 30px rgba(26,20,16,0.12);
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'Montserrat', sans-serif; background-color: var(--cream); color: var(--text); font-size: 15px; line-height: 1.7; overflow-x: hidden; }
  body.auth-locked { overflow: hidden; }

  /* HEADER */
  header {
    background: rgba(13,11,8,0.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    position: fixed; top: 0; width: 100%; z-index: 200;
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }
  .header-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between; height: 72px;
  }
  .logo-wrap { display: flex; align-items: center; gap: 14px; text-decoration: none; }
  .logo-img { height: 54px; width: auto; object-fit: contain; }
  .logo-text { display: flex; flex-direction: column; line-height: 1.1; }
  .logo-text .brand { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; color: var(--gold); letter-spacing: 2px; }
  .logo-text .sub { font-family: 'Montserrat', sans-serif; font-size: 0.6rem; color: rgba(255,255,255,0.5); letter-spacing: 5px; text-transform: uppercase; font-weight: 300; }
  nav a { color: rgba(255,255,255,0.65); text-decoration: none; padding: 6px 18px; font-size: 0.72rem; letter-spacing: 2.5px; text-transform: uppercase; font-weight: 500; transition: color 0.25s; }
  nav a:hover { color: var(--gold); }

  /* HERO VIDEO */
  .hero { position: relative; height: 100vh; min-height: 700px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to bottom, rgba(13,11,8,0.65) 0%, rgba(13,11,8,0.2) 40%, rgba(13,11,8,0.25) 60%, rgba(13,11,8,0.88) 100%),
      linear-gradient(to right, rgba(13,11,8,0.35) 0%, transparent 50%, rgba(13,11,8,0.25) 100%);
  }
  .hero-bar-top, .hero-bar-bottom { position: absolute; left: 0; right: 0; height: 55px; background: var(--dark); z-index: 2; }
  .hero-bar-top { top: 0; }
  .hero-bar-bottom { bottom: 0; }
  .hero-grain { position: absolute; inset: 0; z-index: 2; opacity: 0.035; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); background-size: 150px; pointer-events: none; }
  .hero-content { position: relative; z-index: 3; text-align: center; padding: 2rem; animation: fadeUp 1.4s ease both; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
  .hero-eyebrow { font-size: 0.62rem; letter-spacing: 8px; text-transform: uppercase; color: var(--gold); font-weight: 400; margin-bottom: 1.6rem; opacity: 0; animation: fadeUp 1.4s 0.2s ease forwards; }
  .hero-logo-wrap { display: flex; flex-direction: column; align-items: center; gap: 1.4rem; opacity: 0; animation: fadeUp 1.4s 0.4s ease forwards; }
  .hero-logo-img { width: min(340px, 58vw); height: auto; object-fit: contain; }
  .hero-divider { display: flex; align-items: center; gap: 16px; }
  .hero-divider-line { width: 80px; height: 1px; background: linear-gradient(to right, transparent, var(--gold)); }
  .hero-divider-line.right { background: linear-gradient(to left, transparent, var(--gold)); }
  .hero-divider-diamond { color: var(--gold); font-size: 0.7rem; opacity: 0.75; }
  .hero-tagline { font-family: 'Cormorant Garamond', serif; font-size: clamp(0.95rem, 2.2vw, 1.25rem); color: rgba(255,255,255,0.65); letter-spacing: 5px; text-transform: uppercase; font-weight: 300; font-style: italic; }
  .hero-cta-group { display: flex; gap: 1rem; justify-content: center; margin-top: 2.5rem; opacity: 0; animation: fadeUp 1.4s 0.75s ease forwards; }
  .btn-hero-primary { padding: 13px 34px; background: var(--gold); color: var(--dark); font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; text-decoration: none; display: inline-block; transition: background 0.25s, transform 0.2s, box-shadow 0.25s; box-shadow: 0 4px 20px rgba(201,168,76,0.35); }
  .btn-hero-primary:hover { background: #b5923e; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(201,168,76,0.5); }
  .btn-hero-ghost { padding: 13px 34px; background: transparent; color: rgba(255,255,255,0.85); font-family: 'Montserrat', sans-serif; font-weight: 500; font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.35); cursor: pointer; text-decoration: none; display: inline-block; transition: border-color 0.25s, color 0.25s, background 0.25s; }
  .btn-hero-ghost:hover { border-color: var(--gold); color: var(--gold); background: rgba(201,168,76,0.07); }
  .scroll-hint { position: absolute; bottom: 75px; left: 50%; transform: translateX(-50%); z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 8px; opacity: 0; animation: fadeUp 1.8s 1.2s ease forwards; }
  .scroll-hint span { font-size: 0.58rem; letter-spacing: 4px; text-transform: uppercase; color: rgba(255,255,255,0.35); }
  .scroll-mouse { width: 22px; height: 34px; border: 1px solid rgba(255,255,255,0.25); border-radius: 11px; display: flex; justify-content: center; padding-top: 5px; }
  .scroll-wheel { width: 3px; height: 6px; background: var(--gold); border-radius: 2px; animation: scrollDown 2s ease infinite; }
  @keyframes scrollDown { 0% { transform: translateY(0); opacity: 1; } 80% { transform: translateY(12px); opacity: 0; } 100% { transform: translateY(0); opacity: 0; } }

  /* STATS STRIP */
  .stats-strip { background: var(--dark); border-top: 1px solid rgba(201,168,76,0.15); border-bottom: 1px solid rgba(201,168,76,0.15); padding: 2.5rem 2rem; }
  .stats-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-around; align-items: center; flex-wrap: wrap; gap: 2rem; }
  .stat-item { text-align: center; }
  .stat-number { font-family: 'Cormorant Garamond', serif; font-size: 2.6rem; color: var(--gold); font-weight: 300; line-height: 1; }
  .stat-label { font-size: 0.62rem; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-top: 5px; }
  .stat-sep { width: 1px; height: 40px; background: rgba(201,168,76,0.2); }

  /* CONTAINER & SECTIONS */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .section-title { font-family: 'Cormorant Garamond', serif; font-size: 2.6rem; color: var(--dark); text-align: center; margin-bottom: 0.4rem; font-weight: 400; letter-spacing: 1px; }
  .section-sub { text-align: center; color: var(--muted); font-size: 0.65rem; letter-spacing: 4px; text-transform: uppercase; margin-bottom: 3rem; font-weight: 400; }
  .gold-ornament { display: flex; align-items: center; justify-content: center; gap: 14px; margin: 0.8rem auto 0.6rem; }
  .gold-ornament-line { width: 40px; height: 1px; background: var(--gold); opacity: 0.5; }
  .gold-ornament-icon { color: var(--gold); font-size: 0.7rem; }

  /* ROOMS */
  #rooms { padding: 100px 0 80px; background: var(--cream); }
  .rooms-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; }
  .room-card { background: var(--white); border: 1px solid var(--border); overflow: hidden; box-shadow: var(--shadow); transition: transform 0.3s, box-shadow 0.3s; position: relative; }
  .room-card::before { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--gold), transparent); opacity: 0; transition: opacity 0.3s; z-index: 1; }
  .room-card:hover::before { opacity: 1; }
  .room-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(26,20,16,0.15); }
  .room-card .img-wrap { overflow: hidden; }
  .room-card img { width: 100%; height: 200px; object-fit: cover; display: block; transition: transform 0.5s; }
  .room-card:hover img { transform: scale(1.04); }
  .room-info { padding: 1.4rem 1.6rem 1.6rem; }
  .room-name { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; color: var(--dark); margin-bottom: 0.7rem; font-weight: 600; }
  .room-info ul { list-style: none; padding: 0; margin-bottom: 1.2rem; }
  .room-info ul li { color: var(--muted); font-size: 0.82rem; padding: 4px 0; display: flex; align-items: center; gap: 8px; }
  .room-info ul li::before { content: ''; width: 5px; height: 5px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }
  .room-price { display: inline-block; background: var(--dark); color: var(--gold); font-weight: 500; font-size: 0.82rem; padding: 7px 18px; letter-spacing: 1px; font-family: 'Montserrat', sans-serif; }

  /* BOOKING */
  #booking { padding: 80px 0; background: var(--dark2); position: relative; overflow: hidden; }
  #booking::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(45deg, transparent, transparent 60px, rgba(201,168,76,0.02) 60px, rgba(201,168,76,0.02) 61px); }
  #booking .section-title { color: var(--gold-light); }
  #booking .section-sub { color: rgba(255,255,255,0.3); }
  .form-wrapper { max-width: 580px; margin: 0 auto; background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.2); padding: 3rem; box-shadow: 0 0 60px rgba(0,0,0,0.4); position: relative; }
  .form-wrapper::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
  .form-row { margin-bottom: 1.3rem; }
  .form-row label { display: block; font-size: 0.65rem; letter-spacing: 2.5px; text-transform: uppercase; color: rgba(255,255,255,0.4); font-weight: 500; margin-bottom: 8px; }
  .form-row input, .form-row select { width: 100%; padding: 12px 16px; border: 1px solid rgba(201,168,76,0.2); background: rgba(255,255,255,0.05); font-family: 'Montserrat', sans-serif; font-size: 0.92rem; color: #fff; outline: none; transition: border-color 0.2s, box-shadow 0.2s; -webkit-appearance: none; appearance: none; border-radius: 0; }
  .form-row input::placeholder { color: rgba(255,255,255,0.2); }
  .form-row select option { background: var(--dark2); color: #fff; }
  .form-row input:focus, .form-row select:focus { border-color: var(--gold); background: rgba(201,168,76,0.05); }
  .form-row input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.5) sepia(1) saturate(5) hue-rotate(10deg); cursor: pointer; }
  .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.3rem; }
  .total-box { background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.3); padding: 1.2rem 1.6rem; text-align: center; margin: 1.8rem 0; }
  .total-box p { color: rgba(255,255,255,0.35); font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 6px; }
  #total { color: var(--gold); font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; }
  .btn-primary { width: 100%; padding: 15px; background: var(--gold); color: var(--dark); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; transition: background 0.2s, transform 0.15s; }
  .btn-primary:hover { background: #b5923e; transform: translateY(-1px); }

  /* PAYMENT */
  #payment { padding: 100px 0; background: var(--cream); }
  .payment-wrapper { max-width: 440px; margin: 0 auto; background: var(--white); border: 1px solid var(--border); padding: 3rem 2.5rem; text-align: center; box-shadow: var(--shadow); }
  .qr-container { background: var(--cream); border: 1px solid var(--border); padding: 1.8rem; display: inline-block; margin-bottom: 1.4rem; position: relative; }
  .qr-container::before { content: ''; position: absolute; top: 8px; left: 8px; width: 16px; height: 16px; border-top: 2px solid var(--gold); border-left: 2px solid var(--gold); }
  .qr-container::after { content: ''; position: absolute; bottom: 8px; right: 8px; width: 16px; height: 16px; border-bottom: 2px solid var(--gold); border-right: 2px solid var(--gold); }
  #qrImage { width: 180px; height: 180px; display: block; }
  .upi-id { font-size: 0.82rem; color: var(--muted); margin-bottom: 0.4rem; }
  .upi-id strong { color: var(--dark); font-weight: 600; }
  #payAmount { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--dark); margin-bottom: 1.8rem; font-weight: 400; }
  .payment-wrapper .form-row { text-align: left; margin-bottom: 1rem; }
  .payment-wrapper .form-row label { color: var(--muted); }
  .payment-wrapper .form-row input { border: 1px solid var(--border); background: var(--cream); color: var(--text); border-radius: 0; }
  .payment-wrapper .form-row input::placeholder { color: #bbb; }
  .payment-wrapper .form-row input:focus { border-color: var(--gold); background: var(--white); }
  .btn-confirm { width: 100%; padding: 14px; background: var(--dark); color: var(--gold); font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; transition: background 0.2s; margin-top: 0.6rem; }
  .btn-confirm:hover { background: #2E1F0E; }

  /* FOOTER */
  footer { background: var(--dark); padding: 3rem 2rem; text-align: center; position: relative; }
  footer::before { content: ''; display: block; width: 100%; height: 2px; background: linear-gradient(90deg, transparent 0%, var(--gold) 30%, var(--gold) 70%, transparent 100%); margin-bottom: 3rem; }
  .footer-logo { height: 65px; width: auto; object-fit: contain; margin-bottom: 1.5rem; }
  .footer-copy { color: rgba(255,255,255,0.25); font-size: 0.72rem; letter-spacing: 2px; }
  .footer-copy span { color: var(--gold); opacity: 0.8; }

  /* REVEAL */
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* FEATURE SECTIONS */
  .feature-section { padding: 90px 0; }
  .feature-grid { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 26px; align-items: stretch; }
  .feature-card {
    background: var(--white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    padding: 1.6rem;
  }
  .feature-card-dark {
    background: var(--dark2);
    border: 1px solid rgba(201,168,76,0.2);
    color: rgba(255,255,255,0.9);
  }
  .tour-frame {
    width: 100%;
    min-height: 460px;
    border: 0;
    display: block;
    background: #000;
  }
  .tour-count {
    display: inline-block;
    margin: 0.4rem 0 1rem;
    padding: 6px 12px;
    border: 1px solid rgba(201,168,76,0.35);
    color: var(--gold-light);
    font-size: 0.72rem;
    letter-spacing: 1.6px;
    text-transform: uppercase;
  }
  .tour-room-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  .tour-room-btn {
    border: 1px solid rgba(201,168,76,0.35);
    background: rgba(201,168,76,0.08);
    color: var(--gold-light);
    padding: 10px 12px;
    cursor: pointer;
    text-align: left;
    font-size: 0.78rem;
    line-height: 1.3;
  }
  .tour-room-btn strong { display: block; font-size: 0.82rem; }
  .tour-room-btn small { color: rgba(255,255,255,0.65); }
  .tour-room-btn.active {
    background: var(--gold);
    color: var(--dark);
    border-color: var(--gold);
    font-weight: 600;
  }
  .feature-list { list-style: none; margin-top: 1rem; }
  .feature-list li { margin-bottom: 0.5rem; color: var(--muted); font-size: 0.9rem; }
  .feature-list li::before { content: "◆ "; color: var(--gold); }

  /* SMART RECOMMENDER */
  #recommender { background: #f6f1e7; }
  .reco-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .reco-result {
    margin-top: 1rem;
    border: 1px dashed var(--gold);
    background: rgba(201,168,76,0.08);
    padding: 1rem;
  }
  .reco-result h4 { font-family: 'Cormorant Garamond', serif; color: var(--dark); margin-bottom: 0.4rem; font-size: 1.4rem; }

  /* LOCAL EXPERIENCE MAP */
  #local-map { background: var(--cream); }
  .map-wrap { border: 1px solid var(--border); box-shadow: var(--shadow); overflow: hidden; }
  .map-wrap iframe { width: 100%; min-height: 420px; border: 0; display: block; }
  .experience-grid { margin-top: 20px; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; }
  .experience-card { border: 1px solid var(--border); background: var(--white); padding: 1rem; }
  .experience-card h4 { margin-bottom: 0.4rem; font-size: 1rem; color: var(--dark); }
  .experience-card p { color: var(--muted); font-size: 0.85rem; }

  /* AUTH SECTION */
  #auth { background: var(--dark); }
  #auth .section-title { color: var(--gold-light); }
  #auth .section-sub { color: rgba(255,255,255,0.3); }
  .auth-box {
    max-width: 760px;
    margin: 0 auto;
    border: 1px solid rgba(201,168,76,0.2);
    background: rgba(255,255,255,0.04);
    box-shadow: 0 0 60px rgba(0,0,0,0.35);
    padding: 1.8rem;
  }
  .auth-tabs { display: flex; gap: 8px; margin-bottom: 1.2rem; }
  .auth-tab {
    flex: 1;
    background: transparent;
    border: 1px solid rgba(201,168,76,0.3);
    color: rgba(255,255,255,0.7);
    padding: 12px;
    cursor: pointer;
    font-size: 0.75rem;
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }
  .auth-tab.active { background: var(--gold); color: var(--dark); border-color: var(--gold); font-weight: 600; }
  .auth-pane { display: none; }
  .auth-pane.active { display: block; }
  .otp-row { display: grid; grid-template-columns: 1fr auto; gap: 10px; }
  .btn-secondary {
    padding: 12px 16px;
    border: 1px solid rgba(201,168,76,0.5);
    background: transparent;
    color: var(--gold-light);
    cursor: pointer;
    letter-spacing: 1px;
    font-size: 0.74rem;
    text-transform: uppercase;
  }
  .auth-note { margin-top: 12px; color: rgba(255,255,255,0.45); font-size: 0.78rem; }

  /* LOGIN GATEWAY (FIRST SCREEN) */
  #authGateway {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background:
      linear-gradient(to bottom, rgba(13,11,8,0.94), rgba(13,11,8,0.97)),
      url("https://images.pexels.com/photos/258154/pexels-photo-258154.jpeg?auto=compress&cs=tinysrgb&w=1920") center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .gateway-shell {
    width: min(860px, 96vw);
    border: 1px solid rgba(201,168,76,0.22);
    background: rgba(26,20,16,0.86);
    box-shadow: 0 0 60px rgba(0,0,0,0.5);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 1.4rem;
  }
  .gateway-head { text-align: center; margin-bottom: 1rem; }
  .gateway-head h2 { color: var(--gold-light); font-family: 'Cormorant Garamond', serif; font-size: 2.1rem; font-weight: 500; }
  .gateway-head p { color: rgba(255,255,255,0.55); font-size: 0.78rem; letter-spacing: 2px; text-transform: uppercase; }

  @media (max-width: 1024px) {
    .feature-grid { grid-template-columns: 1fr; }
    .tour-frame { min-height: 360px; }
  }
  @media (max-width: 900px) {
    .header-inner { height: auto; padding-top: 10px; padding-bottom: 10px; gap: 12px; flex-wrap: wrap; }
    nav { width: 100%; display: flex; flex-wrap: wrap; justify-content: center; gap: 4px; }
    nav a { padding: 6px 10px; font-size: 0.64rem; letter-spacing: 1.6px; }
    .reco-grid, .otp-row { grid-template-columns: 1fr; }
    .tour-room-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    body { font-size: 14px; }
    .form-row-2 { grid-template-columns: 1fr; }
    .header-inner { padding: 0 1.2rem; }
    .hero-cta-group { flex-direction: column; align-items: center; }
    .stat-sep { display: none; }
    .container { padding: 0 1rem; }
    .section-title { font-size: 2rem; }
    .tour-frame { min-height: 250px; }
    .map-wrap iframe { min-height: 300px; }
    .auth-box { padding: 1.2rem; }
    .gateway-shell { padding: 1rem; }
    .gateway-head h2 { font-size: 1.8rem; }
  }
</style>
</head>
<body>

<!-- LOGIN/SIGNUP GATEWAY -->
<section id="authGateway" aria-label="Login Signup Gateway">
  <div class="gateway-shell">
    <div class="gateway-head">
